# cactus-react-native@1.12.0 peer-declares react-native-nitro-modules@^0.33.9,
# but the project pins ^0.34.1 (which is compatible at runtime — nitro-modules
# 0.34.x is API-compatible with 0.33.x for cactus's needs). Legacy-peer-deps
# lets npm complete the install without the peer-range assertion.
legacy-peer-deps=true
